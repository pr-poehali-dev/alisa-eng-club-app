{
  "tests": [
    {
      "name": "me без токена — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "me"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "string"}
    },
    {
      "name": "login неверный пароль — 401",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "anna@alisaeng.ru", "password": "wrongpass"},
      "expectedStatus": 401,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "string"}
    },
    {
      "name": "login верные данные — 200",
      "method": "POST",
      "path": "/",
      "body": {"action": "login", "email": "anna@alisaeng.ru", "password": "alisa123"},
      "expectedStatus": 200,
      "bodyMatcher": "partial",
      "expectedBody": {"token": "string", "user": {"email": "string"}}
    },
    {
      "name": "list_users без токена — 403",
      "method": "POST",
      "path": "/",
      "body": {"action": "list_users"},
      "expectedStatus": 403,
      "bodyMatcher": "partial",
      "expectedBody": {"error": "string"}
    }
  ]
}
